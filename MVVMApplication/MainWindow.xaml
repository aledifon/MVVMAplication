<Window x:Class="MVVMApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVMApplication"
        xmlns:vm="clr-namespace:MVVMApplication.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="800">
    <Grid>
        <!--Main Rows Definition-->
        <Grid.RowDefinitions>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="70*"/>
        </Grid.RowDefinitions>
        
        <!--Commands Butttons-->
        <StackPanel             
            Orientation="Horizontal" 
            HorizontalAlignment="Center">
            <!--d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=True}"-->
            <Button Content="Get Clients" Width="75" Height="30" Margin="0,0,5,0"
                    Command="{Binding GetAllClientsCommand}"/>
            <Button Content="Get Orders" Width="75" Height="30" Margin="0,0,5,0"
                    Command="{Binding GetAllOrdersCommand}"/>
            <Button Content="Get Articles" Width="75" Height="30" Margin="0,0,5,0"
                    Command="{Binding GetAllArticlesCommand}"/>
        </StackPanel>

        <!--Global Grid-->
        <Grid 
            Grid.Row="1" 
            Grid.RowSpan="2">
            <!--d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=True}">-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!--Consult Clients/Order/Articles Data-->
            <TabControl 
                HorizontalAlignment="Stretch" 
                VerticalAlignment="Stretch">
                <TabItem Header="Clients">
                    <DataGrid 
                        ItemsSource="{Binding Clients}" 
                        SelectedItem="{Binding SelectedClient}" 
                        AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Client Name" Binding="{Binding ClientName}"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}"/>
                            <DataGridTextColumn Header="Telephone" Binding="{Binding Telephone}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Orders">
                    <DataGrid 
                        ItemsSource="{Binding Orders}" 
                        SelectedItem="{Binding SelectedOrder}" 
                        AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="C-Client" Binding="{Binding CClient}"/>
                            <DataGridTextColumn Header="Date Order" Binding="{Binding DateOrder}"/>
                            <DataGridTextColumn Header="Type of Payment" Binding="{Binding TypePayment}"/>
                        </DataGrid.Columns>
                    </DataGrid>                     
                </TabItem>
                <TabItem Header="Articles">
                    <DataGrid 
                        ItemsSource="{Binding Articles}" 
                        SelectedItem="{Binding SelectedArticle}"
                        AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Section" Binding="{Binding Section}"/>
                            <DataGridTextColumn Header="Article Name" Binding="{Binding ArticleName}"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price}"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}"/>
                            <DataGridTextColumn Header="Origin Country" Binding="{Binding OriginCountry}"/>
                        </DataGrid.Columns>
                    </DataGrid>                     
                </TabItem>
            </TabControl>

            <!--Selected Data-->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30*"/>
                    <RowDefinition Height="25*"/>
                    <RowDefinition Height="40*"/>
                </Grid.RowDefinitions>
                
                <StackPanel>
                    <Label Content="Client Data" FontWeight="Bold"/>
                    <Label Content="Client Name"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedClient.ClientName, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Address"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedClient.Address, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Location"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedClient.Location, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Telephone"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedClient.Telephone, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Label Content="Order Data" FontWeight="Bold"/>
                    <Label Content="C-client"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedOrder.CClient, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Date order"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedOrder.DateOrder, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Type of payment"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedOrder.TypePayment, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Row="2">
                    <Label Content="Article Data" FontWeight="Bold"/>
                    <Label Content="Section"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedArticle.Section, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Article Name"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedArticle.ArticleName, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Price"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedArticle.Price, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Date"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedArticle.Date, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Origin Country"/>
                    <TextBox Margin="5,0,5,0" Text="{Binding SelectedArticle.OriginCountry, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
